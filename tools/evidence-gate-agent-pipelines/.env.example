# Provider mode: hybrid | gemini | openai | ollama | mock
# hybrid uses the recommended matrix: Gemini for reasoning, Ollama for local fallback,
# and Ollama first for routine implementation.
EG_PROVIDER=hybrid

# Gemini Developer API (preferred hosted provider)
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TEXT_MODEL=gemini-3.5-flash
GEMINI_CODER_MODEL=gemini-3.5-flash
GEMINI_MAX_OUTPUT_TOKENS=1800
GEMINI_TIMEOUT_MS=300000

# OpenAI (optional premium/manual override; not part of the default hybrid route)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEXT_MODEL=gpt-5.2
OPENAI_CODER_MODEL=gpt-5.2
OPENAI_MAX_OUTPUT_TOKENS=1800
OPENAI_TIMEOUT_MS=300000
OPENAI_IMAGE_MODEL=gpt-image-1

# Ollama (guaranteed local fallback)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_DEFAULT_MODEL=qwen3:8b
OLLAMA_CODER_MODEL=qwen2.5-coder:7b
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=1200
OLLAMA_KEEP_ALIVE=15m
OLLAMA_TIMEOUT_MS=600000

# Paid/specialist production services are opt-in and must require human approval.
MESHY_API_KEY=
EG_ALLOW_PAID_IMAGE_GENERATION=false
EG_ALLOW_PAID_3D_GENERATION=false
EG_MAX_PAID_JOB_USD=0

# Optional per-pipeline overrides:
# EG_PROVIDER_STRATEGY=gemini
# EG_PROVIDER_CONCEPT_ART=gemini
# EG_PROVIDER_STORYBOARD=gemini
# EG_PROVIDER_DESIGN_SYSTEM=gemini
# EG_PROVIDER_MODELING_3D=gemini
# EG_PROVIDER_ANIMATION=gemini
# EG_PROVIDER_SHADER_VFX=gemini
# EG_PROVIDER_IMPLEMENTATION=ollama
# EG_PROVIDER_QA=gemini
#
# Force a premium OpenAI pass only when explicitly intended:
# EG_PROVIDER_QA=openai
