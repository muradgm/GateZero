# Provider mode: hybrid | openai | ollama | mock
EG_PROVIDER=hybrid

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TEXT_MODEL=gpt-5.2
OPENAI_CODER_MODEL=gpt-5.2
OPENAI_MAX_OUTPUT_TOKENS=1800
OPENAI_TIMEOUT_MS=300000
OPENAI_IMAGE_MODEL=gpt-image-1

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_DEFAULT_MODEL=qwen3:8b
OLLAMA_CODER_MODEL=qwen2.5-coder:7b
OLLAMA_NUM_CTX=4096
OLLAMA_NUM_PREDICT=1200
OLLAMA_KEEP_ALIVE=15m
OLLAMA_TIMEOUT_MS=600000

# Optional per-pipeline overrides:
# EG_PROVIDER_STRATEGY=openai
# EG_PROVIDER_CONCEPT_ART=openai
# EG_PROVIDER_STORYBOARD=openai
# EG_PROVIDER_DESIGN_SYSTEM=openai
# EG_PROVIDER_MODELING_3D=openai
# EG_PROVIDER_ANIMATION=openai
# EG_PROVIDER_SHADER_VFX=openai
# EG_PROVIDER_IMPLEMENTATION=ollama
# EG_PROVIDER_QA=openai
