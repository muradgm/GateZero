{
  "name": "evidence-gate-agent-pipelines",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.6.0",
  "scripts": {
    "dev": "tsx --env-file=.env apps/orchestrator/src/cli.ts",
    "run:demo": "tsx --env-file=.env apps/orchestrator/src/cli.ts run",
    "status": "tsx --env-file=.env apps/orchestrator/src/cli.ts status",
    "approve": "tsx --env-file=.env apps/orchestrator/src/cli.ts approve",
    "reset": "tsx --env-file=.env apps/orchestrator/src/cli.ts reset",
    "doctor": "tsx --env-file=.env apps/orchestrator/src/cli.ts doctor",
    "typecheck": "tsc --noEmit",
    "test": "tsx --env-file=.env --test tests/**/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}