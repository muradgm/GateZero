{
  "name": "traderframe",
  "version": "0.0.0",
  "private": true,
  "description": "GateZero-controlled research foundation for TraderFrame.",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "format:check": "prettier --check README.md package.json pnpm-workspace.yaml tsconfig.base.json tsconfig.json eslint.config.js prettier.config.js \".github/**/*.yml\" \"apps/**/*.{md,json,ts,js,html,css}\" \"packages/**/*.{md,json,ts,js}\" \"scripts/**/*.ts\" \"docs/**/*.{md,json}\" \"ops/**/*.{md,json}\" \"skills/**/*.{md,json,yaml,yml}\"",
    "check:gate0-evidence-index": "tsx scripts/check-gate0-evidence-index-drift.ts",
    "check:gate0-ci-evidence": "tsx scripts/check-gate0-ci-evidence-freshness.ts",
    "check:gate0-command-center": "tsx scripts/check-gate0-command-center-freshness.ts",
    "check:gate0-command-center-render": "tsx scripts/check-gate0-command-center-render-contract.ts",
    "check:market-workspace": "tsx scripts/check-market-intelligence-workspace.ts",
    "check:simulator-workspace": "tsx scripts/check-simulator-workspace-data.ts",
    "check:case-catalog": "tsx scripts/check-local-case-catalog.ts",
    "check:gate0-skills": "tsx scripts/check-gate0-skill-governance.ts",
    "check:gate0-skill-routing": "tsx scripts/check-gate0-skill-routing.ts",
    "check:gate0-agents": "tsx scripts/check-gate0-agent-manifest.ts",
    "check:gate0-actions-runtime": "tsx scripts/check-gate0-github-actions-runtime.ts",
    "check:gate0-source-links": "tsx scripts/check-gate0-source-link-duplicates.ts",
    "check:gate0-tracklist-sections": "tsx scripts/check-gate0-tracklist-section-length.ts",
    "check:repo-hygiene": "tsx scripts/check-repo-hygiene.ts",
    "check:gate1-contracts": "tsx scripts/check-gate1-contracts.ts",
    "check:gate0-name": "tsx scripts/check-gate0-project-name.ts",
    "check:gate0-docs-coverage": "tsx scripts/check-gate0-docs-coverage.ts",
    "check:gate0-snapshot": "tsx scripts/check-gate0-progress-snapshot-freshness.ts",
    "check:gate0-tracklist": "tsx scripts/check-gate0-tracklist-consistency.ts",
    "check:gate0-reviews": "tsx scripts/check-gate0-review-coverage.ts",
    "check:gate0": "pnpm snapshot:gate0-progress && pnpm snapshot:case-catalog && pnpm snapshot:simulator-workspace && pnpm check:gate0-docs-coverage && pnpm check:gate0-tracklist && pnpm check:gate0-snapshot && pnpm check:gate0-name && pnpm check:gate0-evidence-index && pnpm check:gate0-command-center && pnpm check:gate0-command-center-render && pnpm check:market-workspace && pnpm check:case-catalog && pnpm check:simulator-workspace && pnpm check:gate0-skills && pnpm check:gate0-skill-routing && pnpm check:gate0-agents && pnpm check:gate0-actions-runtime && pnpm check:gate0-source-links && pnpm check:gate0-tracklist-sections && pnpm check:repo-hygiene && pnpm check:gate1-contracts && pnpm check:gate0-reviews && pnpm validate:gate0",
    "inspect:gate0-dry-run": "tsx scripts/inspect-gate0-dry-run.ts",
    "inspect:local-cases": "tsx scripts/inspect-local-cases.ts",
    "lint": "eslint .",
    "preview:web": "tsx scripts/preview-web.ts",
    "refresh:gate0-ci-evidence": "tsx scripts/refresh-gate0-ci-evidence.ts",
    "snapshot:gate0-progress": "tsx scripts/generate-gate0-progress-snapshot.ts",
    "snapshot:simulator-workspace": "tsx scripts/generate-simulator-workspace-data.ts",
    "snapshot:case-catalog": "tsx scripts/generate-local-case-catalog.ts",
    "test": "vitest run",
    "test:ci": "vitest run --no-file-parallelism --maxWorkers=1",
    "typecheck": "tsc -p tsconfig.base.json --noEmit",
    "validate:gate0": "tsx scripts/validate-gate0.ts",
    "verify:gate0": "pnpm check:gate0 && pnpm lint && pnpm format:check && pnpm typecheck && pnpm test:ci"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.28.1"
    }
  }
}
